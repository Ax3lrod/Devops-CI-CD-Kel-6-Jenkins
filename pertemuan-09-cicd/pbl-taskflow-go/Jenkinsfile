pipeline {
    agent {
        docker { 
            image 'ax3lrod/taskflow-ci:latest'
            args '-u root -v /var/run/docker.sock:/var/run/docker.sock --network host'
        }
    }
    
    environment {
        PROJECT_DIR = 'pertemuan-09-cicd/pbl-taskflow-go'
        GOCACHE = "${WORKSPACE}/.cache"
        DATABASE_URL = "postgres://taskflow:taskflow_secret@localhost:5432/taskflow?sslmode=disable"
    }

    stages {
        stage('CI Pipeline (Vet, Test, Coverage)') {
            steps {
                dir("${env.PROJECT_DIR}") {
                    script {
                        echo '📦 Downloading Go Dependencies...'
                        sh 'go mod download'

                        echo '🔍 Running Static Analysis (Vet)...'
                        sh 'go vet ./...'

                        echo '🚀 Starting PostgreSQL Sidecar...'
                        sh "docker rm -f db-container || true"
                        sh "docker run -d --name db-container -p 5432:5432 -e POSTGRES_DB=taskflow -e POSTGRES_USER=taskflow -e POSTGRES_PASSWORD=taskflow_secret postgres:16"
                        
                        try {
                            echo '⏳ Waiting for Database...'
                            sh 'sleep 15'
                            
                            echo '🧪 Running Unit & Integration Tests...'
                            sh "CGO_ENABLED=1 DATABASE_URL='${env.DATABASE_URL}' go test -v -race -tags=integration -buildvcs=false ./..."
                            
                            echo '📊 Checking Coverage Gate...'
                            def coverage = sh(script: "go tool cover -func=cov.out | grep total | awk '{print \$3}' | sed 's/%//'", returnStdout: true).trim()
                            echo "Total Project Coverage: ${coverage}%"
                            
                            if (coverage.toFloat() < 75.0) {
                                error "❌ FAILED: Coverage (${coverage}%) is below 75%!"
                            }

                            echo '🏗️ Compiling Binary...'
                            sh 'go build -buildvcs=false -o bin/taskflow-api ./cmd/server'
                            
                        } finally {
                            echo '🧹 Cleaning up Database container...'
                            sh "docker rm -f db-container || true"
                        }
                    }
                }
            }
            post {
                always {
                    dir("${env.PROJECT_DIR}") {
                        echo '📥 Archiving Coverage Report...'
                        archiveArtifacts artifacts: 'cov.out', allowEmptyArchive: true
                    }
                }
            }
        }
    }
}
